{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JobFinderSettings": [
    {
      "Source": "RabotaBy",
      "LinkTemplate": "https://rabota.by/search/vacancy/?text=*location*%20*speciality*",
      "VacancyTag": {
        "HtmlAttribute": {
          "Value": "vacancy-info"
        }
      },
      "HrefPrefix": "rabota.by/vacancy/",
      "BaseUrl": "https://rabota.by",
      "LocationTransliteration": "Cyrillic",
      "MandatoryLocation": true,
      "ZeroBasedPagination": true,
      "Location": {
        "Attribute": "data-qa",
        "Value": "vacancy-address"
      },
      "Company": {
        "Attribute": "data-qa",
        "Value": "employer-text"
      },
      "Experience": {
        "Attribute": "data-qa",
        "Value": "work-experience"
      }
    },
    {
      "Source": "DevBy",
      "LinkTemplate": "https://jobs.devby.io/?[city_id][]=*location*&filter[search]=*speciality*",
      "VacancyTag": {
        "HtmlAttribute": {
          "Value": "vacancies-list-item"
        }
      },
      "Salary": {
        "Value": "vacancies-list-item__salary"
      },
      "Company": {
        "Value": "vacancies-list-item__company"
      },
      "HrefPrefix": "/vacancies/",
      "BaseUrl": "https://jobs.devby.io",
      "LocationTransliteration": "Latin",
      "AddBaseUrlToHrefPrefix": true
    },
    {
      "Source": "PracaBy",
      "LinkTemplate": "https://praca.by/rabota-*location*/?search%5Bquery%5D=*speciality*",
      "VacancyTag": {
        "HtmlAttribute": {
          "Value": "vac-small__column vac-small__column_2"
        }
      },
      "Salary": {
        "Value": "salary-dotted"
      },
      "HrefPrefix": "/vacancy/",
      "BaseUrl": "https://praca.by",
      "LocationTransliteration": "Latin",
      "AddBaseUrlToHrefPrefix": true,
      "MandatoryLocation": true,
      "Location": {
        "Value": "vac-small__city"
      },
      "Company": {
        "Value": "vac-small__organization"
      },
      "Experience": {
        "Value": "vac-small__experience"
      },
      "TimePosted": {
        "Value": "vac-small__upped-time"
      }
    },
    {
      "Source": "BeBee",
      "LinkTemplate": "https://bebee.com/by/jobs?q=*speciality*&location=*location*",
      "HrefPrefix": "/by/jobs/",
      "BaseUrl": "https://bebee.com/",
      "LocationTransliteration": "Latin",
      "VacancyTag": {
        "HtmlAttribute": {
          "Tag": "article",
          "HtmlAttribute": {
            "Value": "group relative rounded-2xl transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
          }
        }
      },
      "Salary": {
        "Value": "min-w-0 break-words sm:truncate"
      },
      "Location": {
        "Value": "flex items-center gap-1 text-sm text-muted-foreground"
      },
      "Company": {
        "Value": "inline-flex items-center gap-1.5 text-sm text-muted-foreground truncate min-w-0"
      },
      "TimePosted": {
        "Value": "text-[11px] text-muted-foreground mt-1.5 flex items-center gap-1"
      },
      "AddBaseUrlToHrefPrefix": true
    },
    {
      "Source": "Joblum",
      "LinkTemplate": "https://by.joblum.com/jobs?q=*speciality*&sort=0&lo%5B%5D=*location*",
      "VacancyTag": {
        "HtmlAttribute": {
          "Value": "result-wrp row"
        }
      },
      "HrefPrefix": "/job/",
      "BaseUrl": "https://by.joblum.com/",
      "LocationTransliteration": "Cyrillic",
      "AddBaseUrlToHrefPrefix": true,
      "MandatoryLocation": true,
      "Location": {
        "Value": "location"
      },
      "Company": {
        "Value": "company-name"
      },
      "TimePosted": {
        "Value": "date"
      }
    },
    {
      "Source": "LinkedIn",
      "LinkTemplate": "https://www.linkedin.com/jobs/search-results/?keywords=*location*%20*speciality*",
      "HrefPrefix": "/job/",
      "BaseUrl": "https://linkedin.com/",
      "LocationTransliteration": "Latin"
    },
    {
      "Source": "Trabajo",
      "LinkTemplate": "https://by.trabajo.org/работы-*speciality*/*location*",
      "VacancyTag": {
        "HtmlAttribute": {
          "Tag": "li",
          "HtmlAttribute": {
            "Value": "job-item"
          }
        }
      },
      "HrefPrefix": "by.trabajo.org/работа-",
      "BaseUrl": "https://by.trabajo.org/",
      "LocationTransliteration": "Latin"
    },
    {
      "Source": "Belmeta",
      "LinkTemplate": "https://belmeta.com/vacansii?q=*speciality*&l=*location*",
      "VacancyTag": {
        "Tag": "article",
        "HtmlAttribute": {
          "Value": "job no-logo"
        }
      },
      "Salary": {
        "Value": "job-data salary"
      },
      "HrefPrefix": "jobdesc?id=",
      "BaseUrl": "https://belmeta.com",
      "AddBaseUrlToHrefPrefix": true,
      "LocationTransliteration": "Cyrillic",
      "Location": {
        "Value": "job-data region"
      },
      "Company": {
        "Value": "job-data company"
      },
      "TimePosted": {
        "Value": "from"
      }
    }
  ]
}