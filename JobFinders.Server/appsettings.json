{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JobFinderSettings": [
    {
      "Source": "RabotaBy",
      "LinkTemplate": "https://rabota.by/search/vacancy/?text=*location*%20*speciality*",
      "HrefCssClass": "vacancy-info",
      "HrefPrefix": "rabota.by/vacancy/",
      "BaseUrl": "https://rabota.by",
      "LocationTransliteration": "Cyrillic",
      "MandatoryLocation": true,
      "ZeroBasedPagination": true
    },
    {
      "Source": "DevBy",
      "LinkTemplate": "https://jobs.devby.io/?[city_id][]=*location*&filter[search]=*speciality*",
      "HrefCssClass": "vacancies-list-item",
      "SalaryCssClass": "vacancies-list-item__salary",
      "HrefPrefix": "/vacancies/",
      "BaseUrl": "https://jobs.devby.io",
      "LocationTransliteration": "Latin",
      "AddBaseUrlToHrefPrefix": true
    },
    {
      "Source": "PracaBy",
      "LinkTemplate": "https://praca.by/rabota-*location*/?search%5Bquery%5D=*speciality*",
      "HrefCssClass": "vac-small__column vac-small__column_2",
      "SalaryCssClass": "salary-dotted",
      "HrefPrefix": "/vacancy/",
      "BaseUrl": "https://praca.by",
      "LocationTransliteration": "Latin",
      "AddBaseUrlToHrefPrefix": true,
      "MandatoryLocation": true
    },
    {
      "Source": "BeBee",
      "LinkTemplate": "https://bebee.com/by/jobs?q=*speciality*&location=*location*",
      "HrefCssClass": "group relative",
      "HrefPrefix": "/by/jobs/",
      "BaseUrl": "https://bebee.com/",
      "LocationTransliteration": "Latin",
      "NodeTag": "article",
      "AddBaseUrlToHrefPrefix": true
    },
    {
      "Source": "Joblum",
      "LinkTemplate": "https://by.joblum.com/jobs?q=*speciality*&sort=0&lo%5B%5D=*location*",
      "HrefCssClass": "result-wrp row",
      "HrefPrefix": "/job/",
      "BaseUrl": "https://by.joblum.com/",
      "LocationTransliteration": "Cyrillic",
      "AddBaseUrlToHrefPrefix": true,
      "MandatoryLocation": true
    },
    {
      "Source": "LinkedIn",
      "LinkTemplate": "https://www.linkedin.com/search/results/all/?&keywords=*location*%20*speciality*",      
      "HrefPrefix": "/job/",
      "BaseUrl": "https://linkedin.com/",
      "LocationTransliteration": "Latin"
    },
    {
      "Source": "Trabajo",
      "LinkTemplate": "https://by.trabajo.org/работы-*speciality*/*location*",
      "HrefCssClass": "job-item",
      "HrefPrefix": "by.trabajo.org/работа-",
      "BaseUrl": "https://by.trabajo.org/",
      "LocationTransliteration": "Latin",
      "NodeTag": "li"
    }
  ]

}